{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "api",
	"account_id": "58f07fb13c26e83dd6109d957083478d",
  "main": "src/index.ts",
	"compatibility_date": "2026-07-12",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
		"logs": { "head_sampling_rate": 1 },
		"traces": { "enabled": true, "head_sampling_rate": 0.05 }
	},
	"triggers": { "crons": ["17 */6 * * *"] },

	// ---- D1 ----
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "ai-video-db",
			"database_id": "42aede4d-4f0c-41da-86d0-4a2bce18d83a",
			"migrations_dir": "../../packages/db/migrations"
		}
	],

	// ---- KV ----
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "5a5e2238fcc5423d8a9d3ec4dd94121f"
		}
	],

	// ---- R2 ----
	"r2_buckets": [
		{ "binding": "ASSETS_BUCKET", "bucket_name": "assets" },
		{ "binding": "RENDERS_BUCKET", "bucket_name": "renders" },
		{ "binding": "UPLOADS_BUCKET", "bucket_name": "uploads" }
		,{ "binding": "EXPORTS_BUCKET", "bucket_name": "exports" }
	],

	// ---- Stream (signed playback + video details; no API token required) ----
	"stream": {
		"binding": "STREAM"
	},

	// ---- Queues (producer only, apps/render is the consumer) ----
	"queues": {
		"producers": [
			{ "binding": "RENDER_QUEUE", "queue": "render-queue" }
		]
	},

	// ---- Workflows (defined in apps/pipeline, bound cross-script) ----
	"workflows": [
		{
			"binding": "GENERATION_PIPELINE",
			"name": "generation-pipeline",
			"class_name": "GenerationPipeline",
			"script_name": "pipeline"
		},
		{
			"binding": "P_VIDEO_GENERATION",
			"name": "p-video-generation",
			"class_name": "PVideoGenerationWorkflow",
			"script_name": "pipeline"
		},
		{
			"binding": "REGEN_IMAGE",
			"name": "regen-image",
			"class_name": "RegenerateSceneImage",
			"script_name": "pipeline"
		},
		{
			"binding": "REGEN_VOICE",
			"name": "regen-voice",
			"class_name": "RegenerateVoiceover",
			"script_name": "pipeline"
		},
		{
			"binding": "REWRITE_SCRIPT",
			"name": "rewrite-script",
			"class_name": "RewriteScript",
			"script_name": "pipeline"
		},
		{
			"binding": "DATA_EXPORT_WORKFLOW",
			"name": "data-export",
			"class_name": "DataExportWorkflow",
			"script_name": "pipeline"
		},
		{
			"binding": "ACCOUNT_DELETION_WORKFLOW",
			"name": "account-deletion",
			"class_name": "AccountDeletionWorkflow",
			"script_name": "pipeline"
		}
	],

	// ---- Service binding to apps/render (for RenderJobDO access) ----
	"services": [
		{ "binding": "RENDER_SERVICE", "service": "render" }
	],

	// ---- Non-secret env vars ----
	"vars": {
		"AI_GATEWAY_BASE_URL": "https://gateway.ai.cloudflare.com/v1/58f07fb13c26e83dd6109d957083478d/ai-video",
		"APP_BASE_URL": "https://api.gokulhansv.workers.dev",
		"PLAYBACK_PROVIDER": "r2",
		"ALLOWED_ORIGINS": "https://aividgen-app.gokulhansv.workers.dev,https://admin.gokulhansv.workers.dev",
		// Set this to the unique code from the Cloudflare Stream dashboard.
	"PLAY_TOKEN_PACKS_JSON": "{\"tokens_500\":500,\"tokens_1500\":1500,\"tokens_5000\":5000}"
	},
	"env": {
		"staging": {
			"name": "api-staging",
			"vars": {
				"AI_GATEWAY_BASE_URL": "https://gateway.ai.cloudflare.com/v1/58f07fb13c26e83dd6109d957083478d/ai-video-staging",
				"APP_BASE_URL": "https://api-staging.gokulhansv.workers.dev",
				"PLAYBACK_PROVIDER": "r2",
				"ALLOWED_ORIGINS": "https://zellyo-app-staging.gokulhansv.workers.dev",
				"PLAY_TOKEN_PACKS_JSON": "{\"tokens_500\":500,\"tokens_1500\":1500,\"tokens_5000\":5000}"
			},
			"d1_databases": [{ "binding": "DB", "database_name": "ai-video-db-staging", "database_id": "4e5232f4-2277-4e1f-803c-daf9ec149bd0", "migrations_dir": "../../packages/db/migrations" }],
			"kv_namespaces": [{ "binding": "KV", "id": "dd78aadb20cf44178b5bcb83b8b92a7a" }],
			"r2_buckets": [
				{ "binding": "ASSETS_BUCKET", "bucket_name": "assets-staging" },
				{ "binding": "RENDERS_BUCKET", "bucket_name": "renders-staging" },
				{ "binding": "UPLOADS_BUCKET", "bucket_name": "uploads-staging" },
				{ "binding": "EXPORTS_BUCKET", "bucket_name": "exports-staging" }
			],
			"queues": { "producers": [{ "binding": "RENDER_QUEUE", "queue": "render-queue-staging" }] },
			"stream": { "binding": "STREAM" },
			"workflows": [
				{ "binding": "GENERATION_PIPELINE", "name": "generation-pipeline-staging", "class_name": "GenerationPipeline", "script_name": "pipeline-staging" },
				{ "binding": "P_VIDEO_GENERATION", "name": "p-video-generation-staging", "class_name": "PVideoGenerationWorkflow", "script_name": "pipeline-staging" },
				{ "binding": "REGEN_IMAGE", "name": "regen-image-staging", "class_name": "RegenerateSceneImage", "script_name": "pipeline-staging" },
				{ "binding": "REGEN_VOICE", "name": "regen-voice-staging", "class_name": "RegenerateVoiceover", "script_name": "pipeline-staging" },
				{ "binding": "REWRITE_SCRIPT", "name": "rewrite-script-staging", "class_name": "RewriteScript", "script_name": "pipeline-staging" },
				{ "binding": "DATA_EXPORT_WORKFLOW", "name": "data-export-staging", "class_name": "DataExportWorkflow", "script_name": "pipeline-staging" },
				{ "binding": "ACCOUNT_DELETION_WORKFLOW", "name": "account-deletion-staging", "class_name": "AccountDeletionWorkflow", "script_name": "pipeline-staging" }
			],
			"services": [{ "binding": "RENDER_SERVICE", "service": "render-staging" }]
		}
	}

	// Secrets (set via `wrangler secret put <NAME>`, NOT stored here):
	// MEDIA_INGEST_SIGNING_SECRET must match pipeline (private R2-to-Stream ingest).
	// OPENAI_API_KEY, GEMINI_API_KEY, REPLICATE_API_TOKEN, FCM_SERVICE_ACCOUNT_JSON,
	// EMAIL_API_KEY, BETTER_AUTH_SECRET, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET,
	// R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY (R2 S3-API creds for
	// presigned URLs — not in CONTRACTS.md, see README "Deviations"),
	// GOOGLE_PLAY_SERVICE_ACCOUNT_JSON (Play Billing verification — also not in
	// CONTRACTS.md, see README "Deviations").
}
