{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"types": ["@cloudflare/workers-types"],
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"allowJs": true,
		"baseUrl": ".",
		"paths": {
			"@app/db": ["../../packages/db/src/index.js"],
			"@app/db/schema": ["../../packages/db/src/schema.js"],
			"@app/shared": ["../../packages/shared/src/index.ts"],
			"@app/shared/openapi": ["../../packages/shared/src/openapi.ts"]
		}
	},
	"include": ["src", "worker-configuration.d.ts"]
}
