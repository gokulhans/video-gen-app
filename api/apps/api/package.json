{
	"name": "@app/api",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --ip 0.0.0.0 --port 8787 --persist-to ../../.wrangler/state",
		"deploy": "wrangler deploy",
		"test": "tsx --test test/*.test.mjs",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate --config ../../packages/db/drizzle.config.ts"
	},
	"dependencies": {
		"@app/db": "workspace:*",
		"@app/shared": "workspace:*",
		"@hono/zod-validator": "^0.8.0",
		"aws4fetch": "^1.0.20",
		"better-auth": "^1.6.0",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.6.16",
		"nanoid": "^5.1.5",
		"zod": "^4.0.5"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260708.1",
		"miniflare": "4.20260701.0",
		"tsx": "4.21.0",
		"typescript": "^5.7.0",
		"wrangler": "^4.110.0"
	}
}
